        $isAdminActor = $actor && (($actor->role ?? '') === 'ADMIN' || (bool)($actor->is_root_owner ?? false));
    }
    if (!$isAdminActor) {
        return response()->json(['message' => 'Chỉ quản trị viên (ADMIN) mới được reset mật khẩu nhân viên.'], 403);
