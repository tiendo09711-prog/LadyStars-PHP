Route::get('/staff', function () {
    $users = \App\Models\User::query()->orderBy('name')->get();
    $creatorIds = $users->pluck('created_by_id')->filter()->unique()->values()->all();
    $creators = User::whereIn('id', $creatorIds)->get()->keyBy('id');

    $assignRows = DB::table('user_warehouse_assignments')
        ->whereIn('user_id', $users->pluck('id'))
        ->get()
        ->groupBy('user_id');
    $branchIds = collect($assignRows)->flatMap(fn ($rows) => $rows->pluck('branch_id'))
        ->merge($users->pluck('default_warehouse_id'))
        ->filter()
        ->unique()
        ->values()
        ->all();
    $branchMap = \App\Models\Branch::whereIn('id', $branchIds)->get()->keyBy('id');

    $items = $users->map(function ($user) use ($assignRows, $branchMap, $creators) {
        $aids = $assignRows->get($user->id, collect());
        $assigned = $aids->map(function ($row) use ($branchMap) {
            $b = $branchMap->get($row->branch_id);
            return $b ? [
                '_id' => (string) $b->id,
                'id' => $b->id,
                'name' => $b->name,
                'code' => $b->code,
            ] : null;
        })->filter()->values()->all();
        $names = collect($assigned)->pluck('name')->filter()->values()->all();

        return [
            '_id' => (string) $user->id,
            'id' => $user->id,
            'name' => $user->name,
            'email' => $user->email,
            'phone' => $user->phone,
            'role' => $user->role,
            'status' => $user->status,
            'branchId' => $user->branch_id ? (string) $user->branch_id : null,
            'defaultWarehouseId' => $user->default_warehouse_id ? (string) $user->default_warehouse_id : null,
            'assignedWarehouseIds' => $assigned,
            'warehouseNames' => $names,
            'isRootOwner' => (bool) $user->is_root_owner,
            'isActive' => (bool) $user->is_active,
            'lastLoginAt' => $user->last_login_at ? $user->last_login_at->toISOString() : null,
            'createdAt' => $user->created_at ? $user->created_at->toISOString() : null,
            'updatedAt' => $user->updated_at ? $user->updated_at->toISOString() : null,
            'createdById' => $user->created_by_id && $creators->has($user->created_by_id)
                ? ['_id' => (string) $user->created_by_id, 'name' => $creators->get($user->created_by_id)->name ?? null]
                : ($user->created_by_id ? (string) $user->created_by_id : null),
        ];
    })->values();

    return response()->json([
        'items' => $items,
        'total' => $items->count(),
    ]);
});

Route::post('/staff', function () {
    $req = request();
    // Backend permission guard (triệt để): only ADMIN/root can manage staff when token identifies user
    $auth = request()->header('Authorization', '');
    $isAdminActor = true;
    if (preg_match('/local-laravel-token-(\d+)/', $auth, $m)) {
        $actor = User::find((int) $m[1]);
        $isAdminActor = $actor && (($actor->role ?? '') === 'ADMIN' || (bool)($actor->is_root_owner ?? false));
    }
    if (!$isAdminActor) {
        return response()->json(['message' => 'Chỉ quản trị viên (ADMIN) mới được tạo nhân viên.'], 403);
    }

    $name = trim((string) $req->input('name'));
    $email = trim((string) $req->input('email'));
    $password = (string) $req->input('password');
    $phone = trim((string) $req->input('phone'));
    $status = (string) $req->input('status', 'ACTIVE');
    $assigned = $req->input('assignedWarehouseIds', []);
    $default = $req->input('defaultWarehouseId') ?: (is_array($assigned) && count($assigned) ? $assigned[0] : null);

    if (!$name || !$email || strlen($password) < 6) {
        return response()->json(['message' => 'Thiếu thông tin bắt buộc (Tên, Email, Mật khẩu >=6).'], 422);
    }
    if (\App\Models\User::where('email', $email)->exists()) {
        return response()->json(['message' => 'Email đã tồn tại trong hệ thống.'], 422);
    }

    // Triệt để fix "cần kho trước": auto create a default active branch if none exist and none assigned
    $aids = is_array($assigned) ? $assigned : ($assigned ? [$assigned] : []);
    $aids = array_unique(array_filter(array_map('intval', $aids)));
    if (count($aids) === 0) {
        $hasActiveBranch = \App\Models\Branch::where('is_active', true)->exists();
        if (!$hasActiveBranch) {
            $defB = \App\Models\Branch::create([
                'name' => 'Kho Mặc định',
                'code' => 'DF' . substr((string) time(), -4),
                'is_active' => true,
            ]);
            $aids = [$defB->id];
            $default = (string) $defB->id;
        }
    }

    $creator = \App\Models\User::query()
        ->where('role', 'ADMIN')
        ->orWhere('is_root_owner', true)
        ->orderByDesc('is_root_owner')
        ->first() ?? \App\Models\User::query()->first();

    $user = \App\Models\User::create([
        'name' => $name,
        'email' => $email,
        'password' => Hash::make($password),
        'phone' => $phone ?: null,
        'role' => 'EMPLOYEE',
        'status' => $status,
        'default_warehouse_id' => $default ? (int) $default : null,
        'created_by_id' => $creator?->id,
        'is_active' => $status === 'ACTIVE',
        'is_root_owner' => false,
    ]);

    // Final assignment list (may have been set by auto default kho)
    $finalAids = $aids; // from auto logic or empty
    if (empty($finalAids)) {
        $finalAids = is_array($assigned) ? $assigned : ($assigned ? [$assigned] : []);
    }
    $finalAids = array_unique(array_filter(array_map('intval', $finalAids)));
    DB::table('user_warehouse_assignments')->where('user_id', $user->id)->delete();
    foreach ($finalAids as $bid) {
        if (\App\Models\Branch::where('id', $bid)->exists()) {
            DB::table('user_warehouse_assignments')->insert([
                'user_id' => $user->id,
                'branch_id' => $bid,
                'created_at' => now(),
                'updated_at' => now(),
            ]);
        }
    }

    return response()->json(['ok' => true, '_id' => (string) $user->id, 'id' => $user->id], 201);
});

Route::patch('/staff/{id}', function ($id) {
    $user = \App\Models\User::findOrFail($id);
    // Backend permission guard
    $auth = request()->header('Authorization', '');
    $isAdminActor = true;
    if (preg_match('/local-laravel-token-(\d+)/', $auth, $m)) {
        $actor = User::find((int) $m[1]);
        $isAdminActor = $actor && (($actor->role ?? '') === 'ADMIN' || (bool)($actor->is_root_owner ?? false));
    }
    if (!$isAdminActor) {
        return response()->json(['message' => 'Chỉ quản trị viên (ADMIN) mới được cập nhật nhân viên.'], 403);
    }
    if ($user->is_root_owner) {
        return response()->json(['message' => 'Không thể sửa tài khoản root owner qua giao diện này.'], 403);
    }
    $req = request();
    $data = [];

    if ($req->has('name')) {
        $data['name'] = trim((string) $req->input('name'));
    }
    if ($req->has('email')) {
        $email = trim((string) $req->input('email'));
        if (\App\Models\User::where('email', $email)->where('id', '!=', $id)->exists()) {
            return response()->json(['message' => 'Email đã tồn tại.'], 422);
        }
        $data['email'] = $email;
    }
    if ($req->has('phone')) {
        $data['phone'] = trim((string) $req->input('phone'));
    }
    if ($req->has('status')) {
        $st = (string) $req->input('status');
        $data['status'] = $st;
        $data['is_active'] = $st === 'ACTIVE';
        $data['locked_at'] = $st === 'LOCKED' ? now() : null;
    }
    if ($req->has('defaultWarehouseId')) {
        $dw = $req->input('defaultWarehouseId');
        $data['default_warehouse_id'] = $dw ? (int) $dw : null;
    }

    if (!empty($data)) {
        $user->update($data);
    }

    if ($req->has('assignedWarehouseIds')) {
        $aids = $req->input('assignedWarehouseIds', []);
        $aids = is_array($aids) ? $aids : ($aids ? [$aids] : []);
        $aids = array_unique(array_filter(array_map('intval', $aids)));
        DB::table('user_warehouse_assignments')->where('user_id', $user->id)->delete();
        foreach ($aids as $bid) {
            if (\App\Models\Branch::where('id', $bid)->exists()) {
                DB::table('user_warehouse_assignments')->insert([
                    'user_id' => $user->id,
                    'branch_id' => $bid,
                    'created_at' => now(),
                    'updated_at' => now(),
                ]);
            }
        }
    }

    return response()->json(['ok' => true, '_id' => (string) $id]);
});

Route::patch('/staff/{id}/{action}', function ($id, $action) {
    $user = \App\Models\User::findOrFail($id);
    // Backend permission guard
    $auth = request()->header('Authorization', '');
    $isAdminActor = true;
    if (preg_match('/local-laravel-token-(\d+)/', $auth, $m)) {
        $actor = User::find((int) $m[1]);
        $isAdminActor = $actor && (($actor->role ?? '') === 'ADMIN' || (bool)($actor->is_root_owner ?? false));
    }
    if (!$isAdminActor) {
        return response()->json(['message' => 'Chỉ quản trị viên (ADMIN) mới được thay đổi trạng thái nhân viên.'], 403);
    }
    if ($user->is_root_owner) {
        return response()->json(['message' => 'Không thể thay đổi trạng thái root owner.'], 403);
    }
    if ($action === 'lock') {
        $user->update([
            'status' => 'LOCKED',
            'locked_at' => now(),
            'is_active' => false,
        ]);
    } elseif ($action === 'open') {
        $user->update([
            'status' => 'ACTIVE',
            'locked_at' => null,
            'is_active' => true,
        ]);
    }
    return response()->json(['ok' => true, '_id' => (string) $id, 'action' => $action]);
});

Route::post('/staff/{id}/reset-password', function ($id) {
